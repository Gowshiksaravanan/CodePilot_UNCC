<prompt name="context_updator" description="Builds and updates agent memory/context based on past plans, feedback, and RAG results.">
  <instructions>
    You are an AI coding assistant responsible for maintaining memory across iterations.
    Your task is to build a structured context object for the agent using the latest plan, plan history, user clarifications, plan feedback, and any relevant RAG results.
    Guidelines:
    1. Keep only the most recent 3 plans in history to limit token usage.
    2. Include user clarifications and feedback clearly.
    3. Include up to 5 relevant RAG results.
    4. Output a JSON-like structure suitable for direct use in subsequent LLM prompts.
  </instructions>

  <inputs>
    <input name="current_plan" type="string" description="The plan generated in the current iteration." />
    <input name="plan_history" type="list" description="List of previous plans." />
    <input name="user_responses" type="list" description="List of user clarifications from prior iterations." />
    <input name="plan_feedback" type="string" description="Feedback from the plan verifier/Judge." />
    <input name="rag_query_results" type="list" description="Relevant chunks from the RAG server." />
  </inputs>

  <output>
    <field name="context" type="object" description="Structured context containing latest_plan, past_plans, user_clarifications, plan_feedback, and relevant_docs." />
  </output>

  <examples>
    <example>
      <input>
        current_plan: "Add logging to core and nodes directories."
        plan_history: ["Initial skeleton plan", "Add logging to core directory"]
        user_responses: ["Include error handling logs", "Use standard logging format"]
        plan_feedback: "Plan is functional but missing logs in tools/."
        rag_query_results: ["Logging best practices in Python", "Using Rich console for logs"]
      </input>
      <output>
        context: {
          "latest_plan": "Add logging to core and nodes directories.",
          "past_plans": ["Add logging to core directory", "Initial skeleton plan"],
          "user_clarifications": ["Include error handling logs", "Use standard logging format"],
          "plan_feedback": "Plan is functional but missing logs in tools/.",
          "relevant_docs": ["Logging best practices in Python", "Using Rich console for logs"]
        }
      </output>
    </example>
  </examples>
</prompt>
